# seko-ai — application environment (rendered from SOPS in the homelab).
# Copy to .env for local dev. All keys are prefixed SEKO_.

SEKO_DEBUG=true
SEKO_BASE_URL=http://localhost:8080
SEKO_SESSION_SECRET=change-me-dev-only
SEKO_DATABASE_URL=sqlite:///./seko-ai.db
# base64 of 32 random bytes: `openssl rand -base64 32`
SEKO_MASTER_KEY=

# Authelia OIDC
SEKO_OIDC_ISSUER=https://auth.pushprh.com
SEKO_OIDC_CLIENT_ID=seko-ai
SEKO_OIDC_CLIENT_SECRET=
SEKO_OIDC_USERS_GROUP=llm_users
SEKO_OIDC_ADMINS_GROUP=homelab_admins

# LiteLLM proxy
SEKO_LITELLM_BASE_URL=http://10.37.20.50:4000
SEKO_LITELLM_MASTER_KEY=
# Comma-separated LiteLLM key alias prefixes shown as Services/Agents rows in admin usage.
SEKO_SERVICE_USAGE_ALIASES=hermes
SEKO_LLM_PUBLIC_URL=https://llm.pushprh.com/v1
SEKO_LLM_MODEL=qwen3.6-27b

# Workspace orchestration (Docker over SSH to epyc)
SEKO_DOCKER_HOST=ssh://pushprh@10.37.20.50
SEKO_WORKSPACE_IMAGE=ghcr.io/pushpreet/seko-workspace:latest
SEKO_WORKSPACE_SSH_HOST=epyc.pushprh.com

# Backups (restic -> NAS)
SEKO_RESTIC_REPOSITORY=
SEKO_RESTIC_PASSWORD=
